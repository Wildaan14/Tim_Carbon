{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/mapbiomass/(.*)",
      "destination": "/db_karbon/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*).(tif|tiff|zip)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
